{
  "name": "crabshack-water-pro",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:compile": "tsc electron/main.ts electron/preload.ts --outDir dist-electron --target es2022 --module commonjs --moduleResolution node --esModuleInterop --skipLibCheck",
    "electron:dev": "npm run electron:compile && electron dist-electron/main.js",
    "dist": "npm run build && npm run electron:compile && electron-builder"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-table": "^8.20.5",
    "better-sqlite3": "^11.8.1",
    "lucide-react": "^0.475.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.crabshack.waterqualitypro",
    "productName": "CrabShack Water Quality Pro",
    "directories": {
      "output": "dist-package"
    },
    "files": [
      "dist-electron/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json"
    ],
    "asar": false,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "CrabShack Water Quality Pro",
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "artifactName": "CrabShack Water Quality Pro Setup.${ext}"
    }
  }
}
